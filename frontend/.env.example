# DashChat frontend (Next.js) environment — Auth.js + Argus (OIDC).
# Copy to .env.local for local dev. NEXT_PUBLIC_* vars are inlined into the
# client bundle at build time; in Docker they are passed as build args
# (see frontend/Dockerfile).

# --- Auth.js (NextAuth v5) ---
# Random 32+ byte secret for session JWT/cookie encryption.
#   openssl rand -base64 32
AUTH_SECRET=replace-me
# Public origin of THIS app (the OAuth redirect base). The Argus callback lands
# at ${AUTH_URL}/api/auth/callback/argus. Dev: http://localhost:5002.
AUTH_URL=http://localhost:5002

# --- Argus (OIDC identity provider) ---
# Origin of the Argus deployment (its OIDC issuer origin). Dev: http://localhost:3000.
ARGUS_ISSUER=http://localhost:3000
# Client-visible copy of ARGUS_ISSUER (needed for RP-initiated logout in the browser).
NEXT_PUBLIC_ARGUS_ISSUER=http://localhost:3000
# The trusted client Argus registered for DashChat. These come from Argus's
# OAUTH_CLIENTS config — clientId is public, clientSecret is confidential.
DASHCHAT_CLIENT_ID=dashchat
DASHCHAT_CLIENT_SECRET=replace-me

# --- Backend connection ---
# Origin the /api/* rewrite proxies to (except /api/auth/*, owned by Auth.js).
# Defaults to http://127.0.0.1:5001 for local dev.
# NEXT_PUBLIC_API_ORIGIN=http://127.0.0.1:5001

# Socket.IO connects directly to the backend (not through the Next rewrite).
# Local dev: http://localhost:5001. Production: the backend's reachable URL.
NEXT_PUBLIC_SOCKET_URL=http://localhost:5001
