# DashChat frontend (Next.js) environment.
# Copy to .env.local for local dev. NEXT_PUBLIC_* vars are inlined into the
# client bundle at build time; in Docker they are passed as build args
# (see frontend/Dockerfile).

# --- Clerk ---
# Publishable key (client). Same Clerk instance as the backend.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Secret key (server). Required by @clerk/nextjs middleware + server components.
# Supplied at RUNTIME, not baked into the image.
CLERK_SECRET_KEY=sk_test_xxx

# Clerk routing (App Router).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# --- Backend connection ---
# Origin the /api/* rewrite proxies to. Defaults to http://127.0.0.1:5001 for
# local dev; set to the backend service URL in production.
# NEXT_PUBLIC_API_ORIGIN=http://127.0.0.1:5001

# Socket.IO connects directly to the backend (not through the Next rewrite).
# Local dev: http://localhost:5001. Production: the backend's reachable URL.
NEXT_PUBLIC_SOCKET_URL=http://localhost:5001
