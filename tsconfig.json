{
  // Backend (Node/Express) TypeScript config. Source lives in backend/, compiles
  // to dist/ for production (`npm run build`); dev runs straight from .ts via tsx.
  // The frontend has its own tsconfig under frontend/.
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "backend",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true
  },
  "include": ["backend/**/*.ts"],
  "exclude": ["node_modules", "dist", "frontend", "prisma.config.ts"]
}
