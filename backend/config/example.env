# ----------------------------------------------------------------------------
# DashChat backend environment configuration
# Copy this file to ".env" (in this same backend/config directory) and fill in
# real values. server.ts loads it via: dotenv.config({ path: "backend/config/.env" })
# In hosted deploys (Render) there is no .env file — set these in the dashboard.
# ----------------------------------------------------------------------------

# Port the Express/Socket.IO server listens on.
# Local: 5001. On Render, Render injects PORT (10000) — server.ts reads it.
PORT=5001

# Node environment.
NODE_ENV=development

# --- Database (Postgres / Supabase) ---
# DATABASE_URL: runtime connection. Use Supabase's transaction-mode pooler
# (port 6543, pgbouncer=true) — this is what PrismaClient uses via the pg adapter.
DATABASE_URL=postgresql://USER:PASS@HOST:6543/postgres?pgbouncer=true
# DIRECT_URL: session-mode connection (port 5432). Used ONLY by the Prisma CLI
# for migrations (`prisma migrate deploy`) — pgbouncer transaction mode can't
# run migrations. Locally, if you don't use a pooler, set it to DATABASE_URL.
DIRECT_URL=postgresql://USER:PASS@HOST:5432/postgres

# --- Clerk authentication ---
# Get these from the Clerk dashboard: https://dashboard.clerk.com (API Keys).
# The secret key must stay server-side only — never expose it to the frontend.
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Your frontend origin (used by Clerk for allowed origins / dev).
CLERK_FRONTEND_URL=http://localhost:3000

# --- AWS S3 (image uploads) ---
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=ap-southeast-1
AWS_BUCKET_NAME=your-bucket
